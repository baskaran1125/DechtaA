# ─────────────────────────────────────────────────────────────
# DECHTA Client Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Same database URL as Vendor backend (shared DB)
DATABASE_URL=postgresql://username:password@hostname:5432/dbname

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=30d

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── Frontend URL (CORS) ───────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── MSG91 (Disabled — enable in production) ──────────────────
# MSG91_AUTH_KEY=your_msg91_auth_key_here
# MSG91_TEMPLATE_ID=your_msg91_template_id_here
# MSG91_SENDER_ID=DECHTA
