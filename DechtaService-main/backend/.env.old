# ============================================================
# QC DRIVER APP — Environment Variables
# ============================================================
# Copy this file to .env and update with your actual values


# ──────────────────────────────────────────────────────────
# Node Environment
# ──────────────────────────────────────────────────────────
NODE_ENV=development

# ──────────────────────────────────────────────────────────
# PostgreSQL Database Configuration
# ──────────────────────────────────────────────────────────
DB_HOST=34.68.84.193
DB_PORT=5432
DB_NAME=dechta
DB_USER=appuser
DB_PASSWORD=Quickqc2026
DB_SSL=true
# Server Configuration
# ──────────────────────────────────────────────────────────
PORT=5003
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────
# JWT Configuration (Change this to a strong secret in production)
# ──────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ──────────────────────────────────────────────────────────
# OTP Service Configuration
# Options: "mock" (for development), "twilio", "aws-sns"
# ──────────────────────────────────────────────────────────
OTP_PROVIDER=mock
# Uncomment for Twilio:
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Uncomment for AWS SNS:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ──────────────────────────────────────────────────────────
# File Upload Configuration
# Options: "local" (development), "aws-s3", "gcs", "supabase-storage"
# ──────────────────────────────────────────────────────────
UPLOAD_PROVIDER=local
UPLOAD_DIR=./uploads

# For AWS S3:
# AWS_S3_BUCKET=your_bucket_name
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# For Google Cloud Storage:
# GCS_PROJECT_ID=your_gcp_project_id
# GCS_BUCKET_NAME=your_gcs_bucket
# GCS_KEY_FILE=./service-account-key.json

# ──────────────────────────────────────────────────────────
# Socket.io Configuration
# ──────────────────────────────────────────────────────────
SOCKET_PING_INTERVAL=30000
SOCKET_PING_TIMEOUT=5000

# ──────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────
# Feature Flags (Optional)
# ──────────────────────────────────────────────────────────
ENABLE_REFERRAL_SYSTEM=true
ENABLE_PRIME_MEMBERSHIP=true
ENABLE_CHAT=true
ENABLE_GPS_TRACKING=true

CASHFREE_APP_ID="your_test_app_id_here"
CASHFREE_SECRET_KEY="your_test_secret_key_here"
CASHFREE_ENVIRONMENT="SANDBOX"
PUBLIC_API_URL="http://localhost:5000"
CASHFREE_PAYOUT_CLIENT_ID="your_payout_client_id"
CASHFREE_PAYOUT_SECRET_KEY="your_payout_secret_key"